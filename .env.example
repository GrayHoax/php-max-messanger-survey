# =====================================================
#  MaxBot Feedback — Environment Configuration
#  Copy this file to .env and fill in your values.
# =====================================================

# ---- Max Messenger Bot Token (required) ----
# Get your token from @MaxBotFather in the Max messenger
BOT_TOKEN=your_max_bot_token_here

# ---- SQLite Database Path ----
# Path inside the container (mapped via docker volume)
DB_PATH=/var/www/html/data/feedback.sqlite

# ---- Survey YAML Configuration ----
SURVEY_CONFIG=/var/www/html/config/survey.yaml

# ---- Nginx Port (host) ----
NGINX_PORT=8080
